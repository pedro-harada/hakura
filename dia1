numero=[]
par= 0
impar= 0
maior= 0
for i in range(5):
    valor=int(input("Digite um numero: "))
    numero.append(valor)
    if valor%2==0:
        par += 1
    else:
        impar += 1
    if valor > maior:
        maior = valor

print("Números digitados:", numero)
print("Números pares:", par)
print("Números ímpares:", impar)
print("Maior número:", maior)
