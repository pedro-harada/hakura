soma = 0

numeros = []


while True:
    print("1- adicionar numero")
    print("2- mostrar soma")
    print("0- sair")
    opção=int(input("digite a opção desejada:"))
    if opção == 1:
            numeros.append(int(input("adicione um numero: ")))
            
    elif opção == 2:
            for n in numeros:
                soma += n
            print("A soma é:",soma)
    elif opção == 0:
            print("saindo...")
            break
    else:
        print("opção invalida")

